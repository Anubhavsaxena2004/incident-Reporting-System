# Django Production Settings
SECRET_KEY=generate-a-secure-random-secret-key-for-production-!!!!
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,your-server-ip

# PostgreSQL Production Settings
DB_NAME=incident_prod_db
DB_USER=incident_prod_user
DB_PASSWORD=generate-a-secure-production-db-password-!!!!
DB_HOST=db
DB_PORT=5432

# CORS & Security Settings
CORS_ALLOWED_ORIGINS=https://yourdomain.com
SECURE_SSL_REDIRECT=True

# Redis Caching Settings
REDIS_URL=redis://redis:6379/1

